# ============================================================
#  ERP SYSTEM - Environment Variables
#  Bu faylni nusxalang: cp .env.example .env
#  Keyin .env faylini o'z ma'lumotlaringiz bilan to'ldiring
# ============================================================

# --- Django asosiy ---
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL Ma'lumotlar bazasi ---
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=your_strong_password
DB_HOST=localhost
DB_PORT=5432

# --- JWT Token muddati ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Email (xabarnomalar uchun) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# --- Media fayllar ---
MEDIA_URL=/media/
MEDIA_ROOT=media/

# --- To'lov sozlamalari ---
MONTHLY_FEE_DEFAULT=500000

# --- Timezone ---
TIME_ZONE=Asia/Tashkent

# --- Notifications (ixtiyoriy) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:8000,https://yourdomain.com

# --- Production uchun (server da to'ldiring) ---
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DEBUG=False
